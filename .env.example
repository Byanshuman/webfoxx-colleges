# WebFoxx Colleges v1.1.0 Environment Configuration

# Server & App
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="WebFoxx Colleges"
NEXT_PUBLIC_TAGLINE="Find Colleges. Not Spam."

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/webfoxx_colleges?schema=public"

# Authentication & Security
JWT_SECRET="super-secret-jwt-key-webfoxx-colleges-2026"
JWT_EXPIRATION="7d"
OTP_EXPIRATION_MINUTES=10

# SMS / OTP Provider (Priority: Mobile OTP Login)
SMS_PROVIDER_API_KEY="your-sms-gateway-api-key"
SMS_SENDER_ID="WFBXCL"

# Storage Configuration (Brochures, Logos, Media)
STORAGE_PROVIDER="local" # 'local' or 's3'
S3_BUCKET_NAME="webfoxx-colleges-assets"
S3_REGION="ap-south-1"

# Analytics & Monitoring
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
NEXT_PUBLIC_CLARITY_PROJECT_ID=""
